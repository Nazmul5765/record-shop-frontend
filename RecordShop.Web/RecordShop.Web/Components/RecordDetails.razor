@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using RecordShop.Web.Models

<h4>@Record.Title</h4>
<h4>@Record.Artist</h4>
<h4>@Record.Genre</h4>
<h4>@Record.ReleaseYear</h4>
<h4>@Record.Price</h4>
<h4>@Record.StockQuantity</h4>

<EditForm Model="Record" OnValidSubmit="SaveChanges">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <label>Title</label>
    <InputText @bind-Value="Record.Title" />
    <label>Artist</label>
    <InputText @bind-Value="Record.Artist" />
    <label>Genre</label>
    <InputText @bind-Value="Record.Genre" />
    <label>ReleaseYear</label>
    <InputNumber @bind-Value="Record.ReleaseYear" />
    <label>Price</label>
    <InputNumber @bind-Value="Record.Price" />
    <label>StockQuantity</label>
    <InputNumber @bind-Value="Record.StockQuantity" />
    <button type="submit">Save Changes</button>

</EditForm>

<button type="button" @onclick="ShowDeleteConfirmation">
    Delete Record
</button>

@if (showDeleteConfirmation)
{
    <p>Are you sure you want to delete this record?</p>
    <button type="button" @onclick="DeleteRecord">Yes, delete</button>
    <button type="button" @onclick="CancelDelete">No, cancel</button>
}

@if (savedMessage != null)
{
    <p>@savedMessage</p>
}


@code {
    private string? savedMessage;
    private bool showDeleteConfirmation = false;
    [Parameter]
    public Record Record { get; set; } = default!;

    private async Task SaveChanges()
    {
        try
        {
            var httpClient = new HttpClient();
            var response = await httpClient.PutAsJsonAsync(
                $"https://localhost:7060/api/albums/{Record.Id}", Record
            );

            if (response.IsSuccessStatusCode)
            {
                savedMessage = "Record updated successfully";   
            }
            else
            {
                savedMessage = "Could not update record.";
            }

        } catch (Exception ex)
        {
            savedMessage = $"Error updating record: {ex.Message}";
        }
    }

    private async Task DeleteRecord()
    {
        try
        {
            var httpClient = new HttpClient();
            var response = await httpClient.DeleteAsync(
                $"https://localhost:7060/api/albums/{Record.Id}");

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/records");   
            }
        } catch (Exception ex)
        {
            savedMessage = $"Error deleting record {ex.Message}";
        }
    }

    private void ShowDeleteConfirmation()
    {
        showDeleteConfirmation = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;   
    }

}
 